# ============================================
# ASYLUM BACKEND — переменные окружения
# Скопируйте этот файл как .env и заполните
# ============================================

# Microsoft SQL Server — строка подключения
# Вариант 1: SQL Server через Docker (РЕКОМЕНДУЕТСЯ для локальной разработки)
DATABASE_URL="sqlserver://localhost:1433;database=asylum_db;user=sa;password=yD5Gwb9sGrXjLX_;trustServerCertificate=true"

# Вариант 2: Локально установленный SQL Server (Windows Auth)
# DATABASE_URL="sqlserver://localhost:1433;database=asylum_db;integratedSecurity=true;trustServerCertificate=true"

# JWT секрет (замените на случайную строку)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Порт сервера
PORT=3000

# Cloudinary (для загрузки фото, если нужно)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
