### 25. Создаем приватную группу (от твоего имени)
# Важно: запиши ID созданной группы из ответа (например, 1)
POST {{baseUrl}}/chats/groups
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Секретный клуб",
  "description": "Только по заявкам",
  "visibility": "REQUEST"
}

